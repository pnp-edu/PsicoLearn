# ====================================================================
# .gitignore OPTIMIZADO PARA FLUTTER & ANÁLISIS DE IA (Manus Optimized)
# ====================================================================

# --- [1] FLUTTER / DART ---
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
*.flutter-plugins*
doc/api/

# --- [2] PLATAFORMA ANDROID ---
**/android/.gradle/
**/android/local.properties
**/android/key.properties
**/android/app/*.keystore
**/android/app/*.jks
**/android/app/*.p12
**/android/app/*.google-services.json
**/android/app/src/main/res/raw/google_services.json
**/android/app/debug/
**/android/app/profile/
**/android/app/release/
*.apk
*.aab

# --- [3] PLATAFORMA IOS ---
**/ios/.generated/
**/ios/.symlinks/
**/ios/Pods/
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/flutter_export_environment.sh
**/ios/Runner/project.xcworkspace
**/ios/Runner/xcuserdata
*.ipa

# --- [4] PLATAFORMAS DESKTOP/WEB ---
**/windows/flutter/ephemeral/
**/windows/flutter/Generated.props
**/windows/CMakeCache.txt
**/windows/CMakeFiles/
**/windows/cmake_install.cmake
**/windows/Runner.sln
**/windows/Runner.vcxproj
**/windows/Runner.vcxproj.filters
**/windows/Runner.vcxproj.user
**/windows/x64/

**/linux/flutter/ephemeral/
**/linux/CMakeCache.txt
**/linux/CMakeFiles/
**/linux/cmake_install.cmake
**/linux/Makefile

**/web/stacktrace.js
**/web/main.dart.js
**/web/main.dart.js.map
**/web/main.dart.js.deps

# --- [5] IDES & HERRAMIENTAS ---
.idea/
*.iml
.vscode/
!.vscode/launch.json
!.vscode/tasks.json
.history/
.DS_Store
Thumbs.db
*.log
*.bak
*.swp
*~

# --- [6] OPTIMIZACIÓN DE CONTEXTO PARA IA (AHORRO DE TOKENS) ---
# Ignoramos activos binarios pesados que la IA no necesita leer para entender el código
assets/animations/
assets/figuras_psicometrico/
assets/data/
*.png
*.jpg
*.jpeg
*.svg
*.lottie
*.gif
*.mp4
*.mp3
*.wav
*.ttf
*.otf

# --- [7] PYTHON & SCRIPTS ---
__pycache__/
*.py[cod]
venv/
.venv/

# --- [8] SEGURIDAD ---
.env*
secrets.*
*.keystore
*.jks
